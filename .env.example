# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Supabase auth + progress sync
# Leave these empty if you only want local demo mode.
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Content source:
# - local: use lib/content/seed.ts (recommended for MVP demo)
# - remote: read scenario cards from Supabase tables
SUPABASE_CONTENT_SOURCE="local"

# Internal pages:
# - false: hide /design and /dev/* in production builds (recommended)
# - true: keep internal design/debug pages accessible in production
ENABLE_INTERNAL_PAGES="false"

# Optional advanced variables for the rental tools module.
# They are not required for the 青年大学习 MVP main flow.
# DATABASE_URL="file:./dev.db"
# OPENAI_API_KEY=""
# OPENAI_BASE_URL=""
# OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""
# EXPORT_SURVIVAL_EMBEDDINGS="true"
