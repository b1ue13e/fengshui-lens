    "knowledge_chunks": [
      {
        "id": "chunk-hukou-employer-qualification",
        "document_id": "doc-sh-2025-grad-hukou",
        "title": "拿 offer 前先问清单位是否具备应届生落户申请资格",
        "content": "2025 年通知明确要求高校提醒毕业生向用人单位核实其是否具备为非上海生源毕业生申请本市户籍的资格，用人单位也应在签订就业协议时如实告知。",
        "why_it_matters": "这一步决定你后面能不能走应届生落户通道，不能把“公司口头说可以”当成正式依据。",
        "actions": [
          "在签约前让 HR 明确回复：单位是否具备当年度应届生落户申请资格。",
          "要求对方说明走的是常规资格、重点扶持单位，还是根本不支持。",
          "把该回答留痕到邮件、IM 或 offer 附件里。"
        ],
        "required_materials": [
          "offer 文本或邮件",
          "HR 回复截图/邮件",
          "岗位名称与工作地说明"
        ],
        "deadline_or_trigger": "签就业协议或接受 offer 之前。",
        "topic_tags": [
          "hukou",
          "offer"
        ],
        "stage_ids": [
          "before_offer",
          "hukou_watchouts"
        ],
        "city_tags": [
          "shanghai"
        ],
        "persona_tags": [
          "fresh_graduate"
        ],
        "keywords": [
          "应届生落户",
          "单位资格",
          "HR",
          "offer"
        ],
        "confidence": "high",
        "verification_required": true,
        "priority": 100,
        "embedding": null
      },
      {
        "id": "chunk-hukou-agreement-boundary",
        "document_id": "doc-sh-2025-grad-hukou",
        "title": "就业协议里不能写“落户办不成就解除协议”",
        "content": "2025 年通知要求用人单位不得在协议中约定“毕业生如未能办妥落户手续则解除就业协议”等损害应届生进沪就业权益的内容。",
        "why_it_matters": "很多风险不是出在流程，而是出在签约时把自己的谈判权提前让掉了。",
        "actions": [
          "逐条检查 offer、三方或补充协议里有没有把落户失败作为解除条件。",
          "如果出现类似表述，先要求修改，再决定是否签字。",
          "保留原版协议截图，避免后续口径反复。"
        ],
        "required_materials": [
          "三方协议/就业协议",
          "补充协议",
          "offer 附件"
        ],
        "deadline_or_trigger": "签任何正式就业文件之前。",
        "topic_tags": [
          "offer",
          "hukou",
          "contract"
        ],
        "stage_ids": [
