      {
        "id": "chunk-contract-minimum-terms",
        "document_id": "doc-cn-labor-contract-law",
        "title": "劳动合同至少要写清工作地点、工资、社保和工时",
        "content": "劳动合同法要求书面合同应包含期限、工作内容和工作地点、工作时间、劳动报酬、社会保险、劳动保护等必备条款。",
        "why_it_matters": "入职后最常见的纠纷并不是“有没有合同”，而是合同关键条款写得模糊，导致后面很难举证。",
        "actions": [
          "重点核对工作地点是否与招聘承诺一致，避免入职后被异地调配。",
          "核对工资结构、发薪日和社保缴纳表述是否完整。",
          "要求一式两份并自己留存签字盖章版。"
        ],
        "required_materials": [
          "劳动合同",
          "offer/岗位 JD",
          "薪酬说明附件"
        ],
        "deadline_or_trigger": "入职当天签合同前完成逐项核对。",
        "topic_tags": [
          "contract",
          "onboarding"
        ],
